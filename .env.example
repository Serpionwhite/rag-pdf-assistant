# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Optional (these are the defaults) ─────────────────────────────────────────
